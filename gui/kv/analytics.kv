#:import MDButton kivymd.uix.button.MDButton
#:import MDTabsPrimary kivymd.uix.tab.MDTabsPrimary
<AnalyticsScreen>:
    name: 'analytics'
    md_bg_color: 1, 1, 1, 1

    MDBoxLayout:
        orientation: 'vertical'
        spacing: 0  # Increased spacing for tablets

        # Responsive Top Bar - Larger for tablets
        TopBar:
            id: top_bar
            size_hint_y: None
            height: dp(64)  # Increased from dp(56) for tablets

        # Main content area (scrollable)
        MDScrollView:
            id: main_scroll_view
            size_hint_y: 1
            bar_width: dp(8)
            MDBoxLayout:
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height

                # Header Section
                MDCard:
                    size_hint_x: 1
                    size_hint_y: None
                    height: dp(90)
                    elevation: 1

                    MDBoxLayout:
                        orientation: 'vertical'
                        spacing: dp(16)
                        padding: dp(20)
                        size_hint_y: None
                        height: self.minimum_height
                        adaptive_height: True

                        # Project Selection Row
                        MDBoxLayout:
                            orientation: 'horizontal'
                            spacing: dp(16)
                            size_hint_y: None
                            height: dp(48)
                            adaptive_height: True

                            MDLabel:
                                text: "Project:"
                                size_hint_x: None
                                width: dp(80)
                                font_size: "16sp"
                                halign: "left"
                                valign: "center"
                                text_size: self.size

                            MDButton:
                                id: project_selector
                                size_hint_x: 1
                                height: dp(48)
                                on_release: root.open_project_menu()
                                MDButtonText:
                                    text: "Select Project for Analysis"

                            MDIconButton:
                                icon: "refresh"
                                size_hint_x: None
                                width: dp(48)
                                height: dp(48)
                                on_release: root.refresh_analysis()

                # Quick Stats Row (outside MDCard)
                MDBoxLayout:
                    orientation: 'horizontal'
                    size_hint_y: None
                    height: dp(140)
                    padding: [0, 0, 0, 0]

                    MDScrollView:
                        id: stats_scroll_view
                        do_scroll_x: False
                        do_scroll_y: True
                        effect_cls: "ScrollEffect"
                        size_hint_y: None
                        height: dp(120)

                        MDGridLayout:
                            id: stats_container
                            cols: 4
                            spacing: dp(24)
                            padding: [0, dp(8)]
                            size_hint_x: 1
                            adaptive_height: True
                            size_hint_y: None
                            height: self.minimum_height

        # Loading Spinner - Larger for tablets
        MDCircularProgressIndicator:
            id: loading_spinner
            size_hint: None, None
            size: dp(56), dp(56)  # Larger spinner for tablets
            pos_hint: {'center_x': .5, 'center_y': .5}
            active: root.is_loading
            
        # Main Analytics Content - Simplified tab approach
        MDCard:
            size_hint_y: 1
            elevation: 1
            padding: dp(16)
            
            MDBoxLayout:
                orientation: 'vertical'
                spacing: dp(16)
                
                # Tab Selection Buttons
                MDBoxLayout:
                    orientation: 'horizontal'
                    spacing: dp(8)
                    size_hint_y: None
                    height: dp(48)
                    
                    MDButton:
                        id: auto_detection_tab_btn
                        size_hint_x: 1
                        height: dp(48)
                        on_release: root.switch_to_tab("auto_detection")
                        MDButtonText:
                            text: "Auto-Detection"
                        
                    MDButton:
                        id: descriptive_tab_btn
                        size_hint_x: 1
                        height: dp(48)
                        on_release: root.switch_to_tab("descriptive")
                        MDButtonText:
                            text: "Descriptive"
                        
                    MDButton:
                        id: inferential_tab_btn
                        size_hint_x: 1
                        height: dp(48)
                        on_release: root.switch_to_tab("inferential")
                        MDButtonText:
                            text: "Inferential"
                        
                    MDButton:
                        id: qualitative_tab_btn
                        size_hint_x: 1
                        height: dp(48)
                        on_release: root.switch_to_tab("qualitative")
                        MDButtonText:
                            text: "Qualitative"
                
                # Tab Content Area
                MDBoxLayout:
                    id: tab_content_area
                    orientation: 'vertical'
                    spacing: dp(16)
                    padding: dp(20)
                    
                    MDLabel:
                        id: tab_content_label
                        text: "Select a project and analysis type above to begin"
                        halign: "center"
                        font_size: "16sp"

        # Bottom Action Bar - Tablet optimized
        MDBoxLayout:
            orientation: 'horizontal'
            spacing: dp(20)  # Increased spacing
            size_hint_y: None
            height: dp(64)  # Increased height for tablets
            padding: [dp(20), dp(12)]  # Increased padding
            
            MDButton:
                size_hint_x: 1
                height: dp(52)
                on_release: root.export_results()
                disabled: not root.analysis_results
                MDButtonText:
                    text: "Export Results"
                
            MDButton:
                size_hint_x: 1
                height: dp(52)
                on_release: root.show_analysis_config()
                MDButtonText:
                    text: "Analysis Config"
                
            MDIconButton:
                icon: "help-circle"
                size_hint_x: None
                width: dp(52)
                user_font_size: "28sp"
                