#:import MDButton kivymd.uix.button.MDButton
#:import MDCard kivymd.uix.card.MDCard
<DashboardScreen>:
    name: "dashboard"
    md_bg_color: 1, 1, 1, 1

    MDBoxLayout:
        orientation: 'vertical'
        size_hint: 1, 1

        # Responsive Top Bar with refresh button - Unified styling
        MDBoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: dp(56)
            md_bg_color: app.theme_cls.primary_color
            padding: dp(8)
            
            TopBar:
                id: top_bar
                
            MDIconButton:
                icon: "refresh"
                theme_icon_color: "Custom"
                icon_color: 1, 1, 1, 1
                size_hint_x: None
                width: dp(48)
                pos_hint: {"center_y": 0.5}
                on_press: root.refresh_dashboard()

        RelativeLayout:
            size_hint: 1, 1
            
            # Main content area
            ScrollView:
                id: main_scroll_view
                size_hint: 1, 1
                
                MDBoxLayout:
                    id: content_layout
                    orientation: 'vertical'
                    padding: dp(24)  # Increased from dp(16) for tablets
                    spacing: dp(20)  # Increased from dp(16) for tablets
                    adaptive_height: True
                    size_hint_y: None
                    height: self.minimum_height

                    MDLabel:
                        text: "Research Dashboard"
                        font_size: "22sp"
                        size_hint_y: None
                        height: self.texture_size[1] + dp(16)
                        halign: "left"

                    # Responsive Stats Grid - Now using ResponsiveGridLayout
                    MDBoxLayout:
                        id: stats_container
                        orientation: 'vertical'
                        adaptive_height: True
                        size_hint_y: None
                        height: self.minimum_height
                        spacing: dp(16)
                        
                        # Stats will be arranged responsively based on screen size
                        # Portrait: 2x2 grid, Landscape tablet: 4x1 row
                        MDGridLayout:
                            id: stats_grid
                            adaptive_height: True
                            size_hint_y: None
                            height: self.minimum_height
                            spacing: dp(16)
                            cols: 1  # Changed from 2 to 1 for narrow window safety

                            StatCard:
                                id: total_responses_card
                                title: "Total Respondents"
                                value: "Loading..."
                                icon: "database"
                                size_hint_y: None
                                size_hint_x: 1  # Force full width
                                # Height will be set dynamically by Python code
                                on_press: root.navigate_to("responses")

                            StatCard:
                                id: active_projects_card
                                title: "Active Projects"
                                value: "Loading..."
                                icon: "folder"
                                size_hint_y: None
                                size_hint_x: 1  # Force full width
                                # Height will be set dynamically by Python code
                                on_press: root.navigate_to("projects")

                            StatCard:
                                id: pending_sync_card
                                title: "Pending Sync"
                                value: "Loading..."
                                icon: "sync"
                                size_hint_y: None
                                size_hint_x: 1  # Force full width
                                # Height will be set dynamically by Python code
                                on_press: root.navigate_to("sync")

                            StatCard:
                                id: team_members_card
                                title: "Team Members"
                                value: "Loading..."
                                note: "Click to manage team members"
                                icon: "account-group"
                                size_hint_y: None
                                size_hint_x: 1  # Force full width
                                # Height will be set dynamically by Python code
                                on_press: root.open_team_management()

                    MDLabel:
                        text: "Dashboard Tools"
                        font_size: "16sp"
                        halign: "left"
                        size_hint_y: None
                        height: self.texture_size[1] + dp(16)

                    # Redesigned Dashboard Tools - Grouped by Function
                    MDBoxLayout:
                        id: tools_container
                        orientation: 'vertical'
                        adaptive_height: True
                        size_hint_y: None
                        height: self.minimum_height
                        spacing: dp(16)
                        
                        # Project Management Group
                        MDCard:
                            id: project_management_card
                            orientation: "vertical"
                            padding: dp(16)
                            spacing: dp(12)
                            elevation: 2
                            size_hint_y: None
                            height: self.minimum_height
                            
                            MDLabel:
                                text: "Project Management"
                                theme_text_color: "Secondary"
                                font_style: "Title"
                                size_hint_y: None
                                height: self.texture_size[1]
                            
                            MDGridLayout:
                                cols: 2
                                adaptive_height: True
                                spacing: dp(12)
                                size_hint_y: None
                                height: self.minimum_height
                                
                                MDButton:
                                    id: projects_btn
                                    style: "outlined"
                                    size_hint_x: 1
                                    on_release: root.navigate_to("projects")
                                    MDButtonText:
                                        text: "Projects"
                                    MDButtonIcon:
                                        icon: "folder"
                                
                                MDButton:
                                    id: team_members_btn
                                    style: "outlined"
                                    size_hint_x: 1
                                    on_release: root.open_team_management()
                                    MDButtonText:
                                        text: "Team Members"
                                    MDButtonIcon:
                                        icon: "account-group"
                        
                        # Data Collection Group
                        MDCard:
                            id: data_collection_card
                            orientation: "vertical"
                            padding: dp(16)
                            spacing: dp(12)
                            elevation: 2
                            size_hint_y: None
                            height: self.minimum_height
                            
                            MDLabel:
                                text: "Data Collection"
                                theme_text_color: "Secondary"
                                font_style: "Title"
                                size_hint_y: None
                                height: self.texture_size[1]
                            
                            MDGridLayout:
                                cols: 2
                                adaptive_height: True
                                spacing: dp(12)
                                size_hint_y: None
                                height: self.minimum_height
                                
                                MDButton:
                                    id: collect_data_btn
                                    style: "outlined"
                                    size_hint_x: 1
                                    on_release: root.navigate_to("data_collection")
                                    MDButtonText:
                                        text: "Collect Data"
                                    MDButtonIcon:
                                        icon: "form-textbox"
                                
                                MDButton:
                                    id: form_builder_btn
                                    style: "outlined"
                                    size_hint_x: 1
                                    on_release: root.navigate_to("form_builder")
                                    MDButtonText:
                                        text: "Form Builder"
                                    MDButtonIcon:
                                        icon: "form-textbox"
                                
                                MDButton:
                                    id: sync_status_btn
                                    style: "outlined"
                                    size_hint_x: 1
                                    on_release: root.navigate_to("sync")
                                    MDButtonText:
                                        text: "Sync Status"
                                    MDButtonIcon:
                                        icon: "cloud-sync"
                        
                        # Data Analysis Group
                        MDCard:
                            id: data_analysis_card
                            orientation: "vertical"
                            padding: dp(16)
                            spacing: dp(12)
                            elevation: 2
                            size_hint_y: None
                            height: self.minimum_height
                            
                            MDLabel:
                                text: "Data Analysis"
                                theme_text_color: "Secondary"
                                font_style: "Title"
                                size_hint_y: None
                                height: self.texture_size[1]
                            
                            MDButton:
                                id: analytics_btn
                                style: "outlined"
                                size_hint_x: 1
                                on_release: root.navigate_to("analytics")
                                MDButtonText:
                                    text: "Analytics"
                                MDButtonIcon:
                                    icon: "chart-bar"

                    MDLabel:
                        text: "Recent Activity"
                        font_size: "16sp"
                        halign: "left"
                        size_hint_y: None
                        height: self.texture_size[1] + dp(16)

                    MDBoxLayout:
                        id: activity_feed_layout
                        orientation: "vertical"
                        spacing: dp(12)  # Increased spacing for tablets
                        adaptive_height: True
                        size_hint_y: None
                        height: self.minimum_height

            # Loading spinner
            MDCircularProgressIndicator:
                id: spinner
                size_hint: None, None
                size: dp(46), dp(46)
                pos_hint: {'center_x': .5, 'center_y': .5}
                active: False
