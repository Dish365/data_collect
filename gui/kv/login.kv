#:import dp kivy.metrics.dp
#:import MDBoxLayout kivymd.uix.boxlayout.MDBoxLayout
#:import MDCard kivymd.uix.card.MDCard
#:import MDButton kivymd.uix.button.MDButton
#:import MDTextField kivymd.uix.textfield.MDTextField
#:import MDLabel kivymd.uix.label.MDLabel
#:import MDIconButton kivymd.uix.button.MDIconButton
#:import FloatLayout kivy.uix.floatlayout.FloatLayout
#:import Window kivy.core.window.Window

<LoginScreen>:
    name: "login"
    # Professional gradient background
    canvas.before:
        Color:
            rgba: 0.05, 0.15, 0.35, 1  # Deep professional blue
        Rectangle:
            pos: self.pos
            size: self.size
        Color:
            rgba: 0.08, 0.18, 0.38, 0.8  # Subtle gradient overlay
        Rectangle:
            pos: self.pos
            size: self.size

    # Responsive centering with better tablet optimization
    AnchorLayout:
        anchor_x: "center"
        anchor_y: "center"
        padding: dp(40) if Window.width > 600 else dp(24)

        MDCard:
            elevation: 12
            radius: [dp(16)]
            padding: [dp(48), dp(40), dp(48), dp(40)]
            md_bg_color: [0.98, 0.98, 0.98, 1]  # Clean white background
            
            # Optimized tablet sizing
            size_hint: None, None
            size: (min(dp(520), Window.width * 0.75), self.minimum_height)
            pos_hint: {"center_x": 0.5, "center_y": 0.5}
            
            # Ensure good width for tablets
            width: max(dp(450), min(dp(650), Window.width * 0.65))
            
            MDBoxLayout:
                orientation: "vertical"
                adaptive_height: True
                spacing: dp(24)
                size_hint_y: None
                height: self.minimum_height

                # Professional header section
                MDBoxLayout:
                    orientation: "vertical"
                    adaptive_height: True
                    spacing: dp(12)
                    size_hint_y: None
                    height: self.minimum_height

                    # App Title - Professional and academic
                    MDLabel:
                        text: "Research Data Collector"
                        font_style: "Label"
                        bold: True
                        halign: "center"
                        size_hint_y: None
                        height: self.texture_size[1] + dp(16)
                        font_size: "32sp" if Window.width > 600 else "28sp"
                        theme_text_color: "Custom"
                        text_color: [0.15, 0.25, 0.45, 1]  # Professional dark blue

                    # Subtitle for context
                    MDLabel:
                        text: "Secure Data Collection Platform"
                        font_style: "Label"
                        halign: "center"
                        size_hint_y: None
                        height: self.texture_size[1] + dp(12)
                        font_size: "16sp" if Window.width > 600 else "14sp"
                        theme_text_color: "Custom"
                        text_color: [0.5, 0.5, 0.5, 1]

                # Form section with proper spacing
                MDBoxLayout:
                    orientation: "vertical"
                    adaptive_height: True
                    spacing: dp(20)
                    size_hint_y: None
                    height: self.minimum_height

                    # Username field
                    MDTextField:
                        id: username
                        hint_text: "Username or Email"
                        mode: "outlined"
                        size_hint_y: None
                        height: dp(64) if Window.width > 600 else dp(56)
                        font_size: "18sp" if Window.width > 600 else "16sp"

                    # Password field
                    FloatLayout:
                        size_hint_y: None
                        height: dp(64) if Window.width > 600 else dp(56)

                        MDTextField:
                            id: password
                            hint_text: "Password"
                            password: not root.password_visible
                            mode: "outlined"
                            size_hint_x: 1
                            size_hint_y: None
                            height: dp(64) if Window.width > 600 else dp(56)
                            pos_hint: {"x": 0, "center_y": 0.5}

                        MDIconButton:
                            icon: "eye-off" if root.password_visible else "eye"
                            on_release: root.toggle_password_visibility()
                            pos_hint: {"right": 0.95, "center_y": 0.5}
                            size_hint: None, None
                            size: (dp(48), dp(48)) if Window.width > 600 else (dp(40), dp(40))

                    # Forgot password link (right-aligned)
                    AnchorLayout:
                        anchor_x: "right"
                        anchor_y: "center"
                        size_hint_y: None
                        height: dp(32)

                        MDLabel:
                            markup: True
                            text: "[ref=forgot][color=377DFF]Forgot Password?[/color][/ref]"
                            size_hint: None, None
                            size: self.texture_size
                            font_size: "16sp" if Window.width > 600 else "14sp"
                            on_ref_press: root.on_forgot_password()
                            halign: "center"
                            valign: "center"

                    # Login button (centered)
                    AnchorLayout:
                        anchor_x: "center"
                        anchor_y: "center"
                        size_hint_y: None
                        height: dp(64) if Window.width > 600 else dp(56)

                        MDButton:
                            id: login_button
                            text: "SIGN IN"
                            size_hint: None, None
                            size: (dp(200), dp(64)) if Window.width > 600 else (dp(180), dp(56))
                            on_release: root.login()
                            md_bg_color: [0.25, 0.50, 0.87, 1]
                            theme_text_color: "Custom"
                            text_color: [1, 1, 1, 1]
                            elevation: 6
                            radius: [dp(12)]

                # Loading and signup section
                MDBoxLayout:
                    orientation: "vertical"
                    adaptive_height: True
                    spacing: dp(16)
                    size_hint_y: None
                    height: self.minimum_height

                    # Loading indicator with professional styling
                    MDBoxLayout:
                        orientation: "horizontal"
                        size_hint_y: None
                        height: dp(40) if root.is_authenticating else dp(0)
                        opacity: 1 if root.is_authenticating else 0
                        spacing: dp(12)
                        pos_hint: {"center_x": 0.5}

                        MDLabel:
                            text: "🔄"
                            size_hint_x: None
                            width: self.texture_size[0]
                            font_size: "20sp"
                            halign: "center"
                            theme_text_color: "Custom"
                            text_color: [0.25, 0.50, 0.87, 1]

                        MDLabel:
                            text: "Authenticating..."
                            font_size: "18sp" if Window.width > 600 else "16sp"
                            halign: "left"
                            theme_text_color: "Custom"
                            text_color: [0.25, 0.50, 0.87, 1]

                    # Divider for visual separation
                    Widget:
                        size_hint_y: None
                        height: dp(20)
                        canvas.after:
                            Color:
                                rgba: 0.85, 0.85, 0.85, 1
                            Line:
                                points: self.x + dp(40), self.center_y, self.right - dp(40), self.center_y
                                width: 1

                    # Signup section with professional styling
                    MDBoxLayout:
                        orientation: "vertical"
                        adaptive_height: True
                        spacing: dp(8)
                        size_hint_y: None
                        height: self.minimum_height

                        MDLabel:
                            text: "New to Research Data Collector?"
                            halign: "center"
                            size_hint_y: None
                            height: self.texture_size[1] + dp(4)
                            font_size: "16sp" if Window.width > 600 else "14sp"
                            theme_text_color: "Custom"
                            text_color: [0.5, 0.5, 0.5, 1]

                        MDLabel:
                            markup: True
                            text: "[ref=signup][color=377DFF]Create Research Account[/color][/ref]"
                            halign: "center"
                            size_hint_y: None
                            height: self.texture_size[1] + dp(4)
                            font_size: "16sp" if Window.width > 600 else "14sp"
                            on_ref_press: root.on_signup()