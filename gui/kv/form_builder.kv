#:import MDButton kivymd.uix.button.MDButton

<FormBuilderScreen>:
    md_bg_color: 1, 1, 1, 1
    FloatLayout:
        MDBoxLayout:
            orientation: 'vertical'
            spacing: 0
            size_hint: 1, 1  # Ensure full screen coverage
            md_bg_color: 0.96, 0.96, 0.96, 1

            # Top Bar - Consistent with other screens
            TopBar:
                id: top_bar
                size_hint_y: None
                height: dp(56)

            Widget:
                size_hint_y: None
                height: dp(15)

            # Enhanced Header Bar
            MDCard:
                orientation: 'vertical'
                size_hint_y: None
                height: dp(80)  # Further reduced to save more space
                elevation: 1
                md_bg_color: 1, 1, 1, 1


                # Project Selection Row - Simplified
                MDBoxLayout:
                    orientation: 'horizontal'
                    padding: [dp(20), dp(16), dp(20), dp(16)]
                    spacing: dp(16)
                    size_hint_y: None
                    height: dp(48)

                    MDLabel:
                        text: "Project:"
                        font_size: "16sp"
                        size_hint_x: None
                        width: dp(80)
                        halign: "left"
                        role: "medium"  # Updated font style

                    MDButton:
                        id: project_spinner
                        text: 'Select Project'
                        on_release: root.open_project_menu()
                        size_hint_x: 1
                        font_size: '16sp'
                        style: "elevated"
                        elevation: 1
                        MDButtonText:
                            text: "Select Project"

                # Description Row
                MDBoxLayout:
                    padding: [dp(20), 0, dp(20), dp(16)]
                    size_hint_y: None
                    height: dp(32)

                    MDLabel:
                        text: "Build professional forms with customizable question types"
                        font_size: "14sp"
                        role: "small"  # Updated font style

            # Main Content Area - Properly sized to fill available space
            MDBoxLayout:
                orientation: 'horizontal'
                spacing: dp(16)
                padding: [dp(32), dp(16), dp(32), 0]
                size_hint_y: 1  # This makes it expand to fill available space

                # Left Sidebar - Question Types
                MDCard:
                    id: sidebar_card
                    orientation: 'vertical'
                    size_hint: (0.32, 1)
                    size_hint_y: 1  # Stretch vertically
                    elevation: 1
                    padding: dp(16)
                    md_bg_color: 1, 1, 1, 1

                    # Sidebar Header
                    MDBoxLayout:
                        orientation: 'vertical'
                        size_hint_y: None
                        height: dp(50)  # Match form canvas header
                        padding: [dp(16), dp(12), dp(16), dp(8)]

                        MDLabel:
                            text: "Question Types"
                            font_style: "Title"
                            size_hint_y: None
                            height: dp(32)

                        MDLabel:
                            text: "Choose question types to build your form"
                            font_size: "12sp"
                            size_hint_y: None
                            height: dp(18)
                            role: "small"  # Updated font style

                    # Scrollable Question Types - Expand to fill remaining space
                    MDScrollView:
                        do_scroll_x: False
                        do_scroll_y: True
                        size_hint: 1, 1  # Fill remaining space in sidebar
                        bar_width: dp(4)
                        bar_color: 0.8, 0.8, 0.8, 1

                        MDBoxLayout:
                            orientation: 'vertical'
                            padding: [dp(16), dp(12), dp(16), dp(16)]
                            spacing: dp(16)  # Reduced spacing for better fit
                            size_hint_y: None
                            height: max(self.minimum_height, self.parent.height)

                            # TEXT RESPONSES SECTION
                            MDBoxLayout:
                                orientation: 'vertical'
                                spacing: dp(12)  # Increased spacing for tablets
                                size_hint_y: None
                                height: self.minimum_height

                                # Section Header
                                MDBoxLayout:
                                    orientation: 'horizontal'
                                    spacing: dp(8)
                                    size_hint_y: None
                                    height: dp(32)  # Larger header for tablets

                                    MDIcon:
                                        icon: "format-text"
                                        size_hint: None, None
                                        size: dp(24), dp(24)  # Larger icon for tablets
                                        theme_icon_color: "Primary"

                                    MDLabel:
                                        text: "Text Responses"
                                        font_size: "16sp"
                                        role: "medium"  # Updated font style

                                # Text Response Buttons - Tablet optimized
                                MDButton:
                                    on_release: root.add_question('text_short')
                                    size_hint_y: None
                                    height: dp(48)  # Tablet-friendly touch target
                                    container_color: 0.2, 0.6, 1, 1  # Blue
                                    style: "filled"
                                    font_size: "15sp"  # Larger font for tablets
                                    elevation: 1
                                    radius: [8, 8, 8, 8]
                                    MDButtonText:
                                        text: "Short Text"
                                        text_color: 1, 1, 1, 1

                                MDButton:
                                    on_release: root.add_question('text_long')
                                    size_hint_y: None
                                    height: dp(48)  # Tablet-friendly touch target
                                    container_color: 0.1, 0.5, 0.9, 1  # Darker Blue
                                    style: "filled"
                                    font_size: "15sp"  # Larger font for tablets
                                    elevation: 1
                                    radius: [8, 8, 8, 8]
                                    MDButtonText:
                                        text: "Long Text"
                                        text_color: 1, 1, 1, 1

                            # NUMERIC RESPONSES SECTION
                            MDBoxLayout:
                                orientation: 'vertical'
                                spacing: dp(12)  # Increased spacing for tablets
                                size_hint_y: None
                                height: self.minimum_height

                                # Section Header
                                MDBoxLayout:
                                    orientation: 'horizontal'
                                    spacing: dp(8)
                                    size_hint_y: None
                                    height: dp(32)  # Larger header for tablets

                                    MDIcon:
                                        icon: "numeric"
                                        size_hint: None, None
                                        size: dp(24), dp(24)  # Larger icon for tablets
                                        theme_icon_color: "Primary"

                                    MDLabel:
                                        text: "Numeric Responses"
                                        font_size: "16sp"
                                        role: "medium"  # Updated font style

                                # Numeric Response Buttons - Tablet optimized
                                MDButton:
                                    on_release: root.add_question('numeric_integer')
                                    size_hint_y: None
                                    height: dp(48)  # Tablet-friendly touch target
                                    container_color: 1, 0.6, 0.2, 1  # Orange
                                    style: "filled"
                                    elevation: 1
                                    radius: [8, 8, 8, 8]
                                    MDButtonText:
                                        text: "Number (Integer)"
                                        text_color: 1, 1, 1, 1

                                MDButton:
                                    on_release: root.add_question('numeric_decimal')
                                    size_hint_y: None
                                    height: dp(48)  # Tablet-friendly touch target
                                    container_color: 0.9, 0.5, 0.1, 1  # Darker Orange
                                    style: "filled"
                                    elevation: 1
                                    radius: [8, 8, 8, 8]
                                    MDButtonText:
                                        text: "Number (Decimal)"
                                        text_color: 1, 1, 1, 1

                            # CHOICE RESPONSES SECTION
                            MDBoxLayout:
                                orientation: 'vertical'
                                spacing: dp(8)  # Reduced spacing
                                size_hint_y: None
                                height: self.minimum_height

                                # Section Header
                                MDBoxLayout:
                                    orientation: 'horizontal'
                                    spacing: dp(8)
                                    size_hint_y: None
                                    height: dp(28)  # Smaller header

                                    MDIcon:
                                        icon: "check-circle-outline"
                                        size_hint: None, None
                                        size: dp(18), dp(18)  # Smaller icon
                                        theme_icon_color: "Primary"

                                    MDLabel:
                                        text: "Choice Responses"
                                        font_size: "15sp"
                                        role: "medium"  # Updated font style

                                # Choice Response Buttons
                                MDButton:
                                    on_release: root.add_question('choice_single')
                                    size_hint_y: None
                                    height: dp(36)
                                    container_color: 0.8, 0.4, 0.2, 1  # Brown
                                    style: "filled"
                                    font_size: "13sp"
                                    elevation: 1
                                    radius: [8, 8, 8, 8]
                                    MDButtonText:
                                        text: "Single Choice"
                                        text_color: 1, 1, 1, 1

                                MDButton:
                                    on_release: root.add_question('choice_multiple')
                                    size_hint_y: None
                                    height: dp(36)
                                    container_color: 0.7, 0.3, 0.1, 1  # Darker Brown
                                    style: "filled"
                                    font_size: "13sp"
                                    elevation: 1
                                    radius: [8, 8, 8, 8]
                                    MDButtonText:
                                        text: "Multiple Choice"
                                        text_color: 1, 1, 1, 1

                            # DATE & TIME SECTION
                            MDBoxLayout:
                                orientation: 'vertical'
                                spacing: dp(8)  # Reduced spacing
                                size_hint_y: None
                                height: self.minimum_height

                                # Section Header
                                MDBoxLayout:
                                    orientation: 'horizontal'
                                    spacing: dp(8)
                                    size_hint_y: None
                                    height: dp(28)  # Smaller header

                                    MDIcon:
                                        icon: "calendar"
                                        size_hint: None, None
                                        size: dp(18), dp(18)  # Smaller icon
                                        theme_icon_color: "Primary"

                                    MDLabel:
                                        text: "Date & Time"
                                        role: "medium"  # Updated font style
                                        theme_text_color: "Primary"
                                        font_size: "15sp"  # Smaller font

                                # Date & Time Buttons
                                MDButton:
                                    on_release: root.add_question('date')
                                    size_hint_y: None
                                    height: dp(36)
                                    container_color: 0.2, 0.7, 0.4, 1  # Green
                                    style: "filled"
                                    font_size: "13sp"
                                    elevation: 1
                                    radius: [8, 8, 8, 8]
                                    MDButtonText:
                                        text: "Date"
                                        text_color: 1, 1, 1, 1

                                MDButton:
                                    on_release: root.add_question('datetime')
                                    size_hint_y: None
                                    height: dp(36)
                                    container_color: 0.1, 0.6, 0.3, 1  # Darker Green
                                    style:"filled"
                                    font_size: "13sp"
                                    elevation: 1
                                    radius: [8, 8, 8, 8]
                                    MDButtonText:
                                        text: "Date & Time"
                                        text_color: 1, 1, 1, 1

                            # LOCATION & GPS SECTION
                            MDBoxLayout:
                                orientation: 'vertical'
                                spacing: dp(8)
                                size_hint_y: None
                                height: self.minimum_height

                                # Section Header
                                MDBoxLayout:
                                    orientation: 'horizontal'
                                    spacing: dp(8)
                                    size_hint_y: None
                                    height: dp(28)

                                    MDIcon:
                                        icon: "map-marker"
                                        size_hint: None, None
                                        size: dp(18), dp(18)
                                        theme_icon_color: "Primary"

                                    MDLabel:
                                        text: "Location & GPS"
                                        role: "medium"  # Updated font style
                                        theme_text_color: "Primary"
                                        font_size: "15sp"

                                # Location Buttons
                                MDButton:
                                    on_release: root.add_question('geopoint')
                                    size_hint_y: None
                                    height: dp(36)
                                    container_color: 0.6, 0.2, 0.8, 1  # Purple
                                    style: "filled"
                                    font_size: "13sp"
                                    elevation: 1
                                    radius: [8, 8, 8, 8]
                                    MDButtonText:
                                        text: "GPS Location"
                                        text_color: 1, 1, 1, 1

                                MDButton:
                                    on_release: root.add_question('geoshape')
                                    size_hint_y: None
                                    height: dp(36)
                                    container_color: 0.5, 0.1, 0.7, 1  # Darker Purple
                                    font_size: "13sp"
                                    style:"filled"
                                    elevation: 1
                                    radius: [8, 8, 8, 8]
                                    MDButtonText:
                                        text: "GPS Area"
                                        text_color: 1, 1, 1, 1

                            # MEDIA SECTION
                            MDBoxLayout:
                                orientation: 'vertical'
                                spacing: dp(8)
                                size_hint_y: None
                                height: self.minimum_height

                                # Section Header
                                MDBoxLayout:
                                    orientation: 'horizontal'
                                    spacing: dp(8)
                                    size_hint_y: None
                                    height: dp(28)

                                    MDIcon:
                                        icon: "camera"
                                        size_hint: None, None
                                        size: dp(18), dp(18)
                                        theme_icon_color: "Primary"

                                    MDLabel:
                                        text: "Media & Files"
                                        role: "medium"  # Updated font style
                                        theme_text_color: "Primary"
                                        font_size: "15sp"

                                # Media Buttons
                                MDButton:
                                    on_release: root.add_question('image')
                                    size_hint_y: None
                                    height: dp(36)
                                    container_color: 0.2, 0.8, 0.8, 1  # Teal
                                    style: "filled"
                                    elevation: 1
                                    radius: [8, 8, 8, 8]
                                    MDButtonText:
                                        text: "Photo/Image"
                                        text_color: 1, 1, 1, 1

                                MDButton:
                                    on_release: root.add_question('audio')
                                    size_hint_y: None
                                    height: dp(36)
                                    container_color: 0.1, 0.7, 0.7, 1  # Darker Teal
                                    style: "filled"
                                    elevation: 1
                                    radius: [8, 8, 8, 8]
                                    MDButtonText:
                                        text: "Audio Recording"
                                        text_color: 1, 1, 1, 1

                                MDButton:
                                    on_release: root.add_question('video')
                                    size_hint_y: None
                                    height: dp(36)
                                    container_color: 0.0, 0.6, 0.6, 1  # Even Darker Teal
                                    style: "filled"
                                    elevation: 1
                                    radius: [8, 8, 8, 8]
                                    MDButtonText:
                                        text: "Video Recording"
                                        text_color: 1, 1, 1, 1

                                MDButton:
                                    on_release: root.add_question('file')
                                    size_hint_y: None
                                    height: dp(36)
                                    container_color: 0.3, 0.9, 0.9, 1  # Lighter Teal
                                    style: "filled"
                                    elevation: 1
                                    radius: [8, 8, 8, 8]
                                    MDButtonText:
                                        text: "File Upload"
                                        text_color: 0, 0, 0, 1

                            # SPECIAL SECTION
                            MDBoxLayout:
                                orientation: 'vertical'
                                spacing: dp(8)
                                size_hint_y: None
                                height: self.minimum_height

                                # Section Header
                                MDBoxLayout:
                                    orientation: 'horizontal'
                                    spacing: dp(8)
                                    size_hint_y: None
                                    height: dp(28)

                                    MDIcon:
                                        icon: "cog"
                                        size_hint: None, None
                                        size: dp(18), dp(18)
                                        theme_icon_color: "Primary"

                                    MDLabel:
                                        text: "Special Types"
                                        role: "medium"  # Updated font style
                                        theme_text_color: "Primary"
                                        font_size: "15sp"

                                # Special Buttons
                                MDButton:
                                    on_release: root.add_question('signature')
                                    size_hint_y: None
                                    height: dp(36)
                                    md_bg_color: 0.4, 0.4, 0.4, 1  # Gray
                                    elevation: 1
                                    radius: [8, 8, 8, 8]
                                    MDButtonText:
                                        text: "Digital Signature"
                                        text_color: 1, 1, 1, 1

                                MDButton:
                                    on_release: root.add_question('barcode')
                                    size_hint_y: None
                                    height: dp(36)
                                    md_bg_color: 0.3, 0.3, 0.3, 1  # Darker Gray
                                    elevation: 1
                                    radius: [8, 8, 8, 8]
                                    MDButtonText:
                                        text: "Barcode/QR Code"
                                        text_color: 1, 1, 1, 1

                                MDButton:
                                    on_release: root.add_question('scale_rating')
                                    size_hint_y: None
                                    height: dp(36)
                                    md_bg_color: 0.5, 0.5, 0.5, 1  # Lighter Gray
                                    elevation: 1
                                    radius: [8, 8, 8, 8]
                                    MDButtonText:
                                        text: "Rating Scale"
                                        text_color: 1, 1, 1, 1

                # Right Panel - Form Canvas
                MDCard:
                    orientation: 'vertical'
                    size_hint: (0.68, 1)
                    size_hint_y: 1  # Stretch vertically
                    elevation: 1
                    md_bg_color: 1, 1, 1, 1
                    padding: dp(16)

                    # Form Canvas Header - Simplified
                    MDBoxLayout:
                        orientation: 'vertical'
                        size_hint_y: None
                        height: dp(50)  # Further reduced
                        padding: [dp(16), dp(12), dp(16), dp(8)]

                        MDLabel:
                            text: "Form Questions"
                            theme_text_color: "Primary"
                            font_style: "Title"
                            size_hint_y: None
                            height: dp(24)

                        MDLabel:
                            text: "Add questions from the left panel to build your form"
                            role: "small"  # Updated font style
                            theme_text_color: "Secondary"
                            font_size: "14sp"
                            size_hint_y: None
                            height: dp(18)

                    # Form Canvas Content Area - Expand to fill remaining space
                    MDScrollView:
                        do_scroll_x: False
                        do_scroll_y: True
                        size_hint: 1, 1  # Fill remaining space
                        bar_width: dp(4)
                        bar_color: 0.8, 0.8, 0.8, 1

                        MDBoxLayout:
                            id: form_canvas
                            orientation: 'vertical'
                            spacing: dp(24)
                            size_hint_y: None
                            height: max(self.minimum_height, self.parent.height)
                            padding: [dp(24), dp(24), dp(24), dp(24)]

                            # Empty state when no questions
                            MDBoxLayout:
                                id: empty_state
                                orientation: 'vertical'
                                spacing: dp(16)
                                size_hint_y: None
                                height: dp(200)

                                Widget:
                                    size_hint_y: None
                                    height: dp(40)

                                MDIcon:
                                    icon: "clipboard-text-outline"
                                    size_hint: None, None
                                    size: dp(64), dp(64)
                                    pos_hint: {'center_x': 0.5}
                                    theme_icon_color: "Hint"

                                MDLabel:
                                    text: "No questions added yet"
                                    font_style: "Label"
                                    theme_text_color: "Hint"
                                    halign: "center"
                                    font_size: "18sp"

                                MDLabel:
                                    text: "Select question types from the left panel to start building your form"
                                    font_style: "Body"
                                    theme_text_color: "Hint"
                                    halign: "center"
                                    font_size: "14sp"

            # Footer - Action buttons at bottom
            MDCard:
                orientation: 'horizontal'
                size_hint_y: None
                height: dp(50)  # Further reduced for maximum content space
                padding: [dp(20), dp(8)]
                spacing: dp(16)
                elevation: 2
                style:"elevated"
                md_bg_color: 1, 0.5, 0, 1

                Widget:
                    size_hint_x: 1

                MDButton:
                    on_release: root.save_form()
                    size_hint: None, None
                    size: dp(120), dp(40)
                    elevation: 2
                    style:'filled'
                    MDButtonText:
                        text: "Save Form"

                MDButton:
                    on_release: root.preview_questions()
                    size_hint: None, None
                    size: dp(100), dp(40)
                    elevation: 2
                    style:"outlined"
                    MDButtonText:
                        text: "Preview"

                Widget:
                    size_hint_x: 1

       