#:import dp kivy.metrics.dp
#:import MDBoxLayout kivymd.uix.boxlayout.MDBoxLayout
#:import MDCard     kivymd.uix.card.MDCard
#:import MDButton kivymd.uix.button.MDButton
#:import MDTextField    kivymd.uix.textfield.MDTextField
#:import MDLabel        kivymd.uix.label.MDLabel
#:import MDCircularProgressIndicator kivymd.uix.progressindicator.MDCircularProgressIndicator
#:import MDIconButton kivymd.uix.button.MDIconButton
#:import FloatLayout kivy.uix.floatlayout.FloatLayout
#:import Window kivy.core.window.Window

<SignUpScreen>:
    name: "signup"
    # full-screen primary color background
    md_bg_color: app.theme_cls.primary_color

    # Use responsive centering that adapts to screen size
    AnchorLayout:
        anchor_x: "center"
        anchor_y: "center"
        padding: dp(24)

        MDCard:
            elevation: 8
            radius: [dp(20)]
            padding: [dp(32), dp(20), dp(32), dp(24)]
            
            # Responsive sizing based on screen dimensions - reduced height
            size_hint: None, None
            size: (min(dp(500), Window.width * 0.85), self.minimum_height)
            pos_hint: {"center_x": 0.5, "center_y": 0.5}
            
            # Ensure minimum width for tablets
            width: max(dp(420), min(dp(650), Window.width * 0.7))

            MDBoxLayout:
                orientation: "vertical"
                spacing: dp(16)
                adaptive_height: True
                size_hint_y: None
                height: self.minimum_height

                # Back button with responsive sizing
                MDBoxLayout:
                    orientation:"horizontal"
                    size_hint_y: None
                    height: dp(32) if Window.width > 600 else dp(24)

                    MDIconButton:
                        icon:"arrow-left"
                        user_font_size: "28sp" if Window.width > 600 else "24sp"
                        size_hint: None, None
                        size: (dp(40), dp(40)) if Window.width > 600 else (dp(32), dp(32))
                        disabled: root.is_registering
                        on_release: root.on_login()

                # Title with responsive typography
                MDLabel:
                    text: "Create Account"
                    font_style: "Display"
                    halign: "center"
                    size_hint_y: None
                    height: self.texture_size[1] + dp(8)
                    font_size: "26sp" if Window.width > 600 else "22sp"
                    theme_text_color: "Primary"

                # Username with responsive sizing
                MDTextField:
                    id: username
                    hint_text: "Choose a username"
                    helper_text: "3-30 characters, letters, numbers, and underscores only"
                    helper_text_mode: "on_focus"
                    mode: "outlined"
                    size_hint_y: None
                    height: dp(56) if Window.width > 600 else dp(48)
                    font_size: "16sp" if Window.width > 600 else "14sp"
                    disabled: root.is_registering
                    text: ""
                    theme_text_color: "Primary"
                    hint_text_color: [0.6, 0.6, 0.6, 1]
                    helper_text_color: [0.5, 0.5, 0.5, 1]
                    text_color: [0, 0, 0, 1]

                # First & Last name side by side with responsive sizing
                MDBoxLayout:
                    orientation: "horizontal"
                    spacing: dp(16) if Window.width > 600 else dp(12)
                    size_hint_y: None
                    height: dp(56) if Window.width > 600 else dp(48)

                    MDTextField:
                        id: first_name
                        hint_text: "First name"
                        helper_text: "Your first name"
                        helper_text_mode: "on_focus"
                        mode: "outlined"
                        font_size: "16sp" if Window.width > 600 else "14sp"
                        disabled: root.is_registering
                        text: ""
                        theme_text_color: "Primary"
                        hint_text_color: [0.6, 0.6, 0.6, 1]
                        helper_text_color: [0.5, 0.5, 0.5, 1]
                        text_color: [0, 0, 0, 1]

                    MDTextField:
                        id: last_name
                        hint_text: "Last name"
                        helper_text: "Your last name"
                        helper_text_mode: "on_focus"
                        mode: "outlined"
                        font_size: "16sp" if Window.width > 600 else "14sp"
                        disabled: root.is_registering
                        text: ""
                        theme_text_color: "Primary"
                        hint_text_color: [0.6, 0.6, 0.6, 1]
                        helper_text_color: [0.5, 0.5, 0.5, 1]
                        text_color: [0, 0, 0, 1]

                # Email with responsive sizing
                MDTextField:
                    id: email
                    hint_text: "Email address"
                    helper_text: "Your institutional or personal email"
                    helper_text_mode: "on_focus"
                    mode: "outlined"
                    size_hint_y: None
                    height: dp(56) if Window.width > 600 else dp(48)
                    font_size: "16sp" if Window.width > 600 else "14sp"
                    disabled: root.is_registering
                    text: ""
                    theme_text_color: "Primary"
                    hint_text_color: [0.6, 0.6, 0.6, 1]
                    helper_text_color: [0.5, 0.5, 0.5, 1]
                    text_color: [0, 0, 0, 1]

                # Institution with responsive sizing
                MDTextField:
                    id: institution
                    hint_text: "Institution or organization"
                    helper_text: "University, company, or research organization"
                    helper_text_mode: "on_focus"
                    mode: "outlined"
                    size_hint_y: None
                    height: dp(56) if Window.width > 600 else dp(48)
                    font_size: "16sp" if Window.width > 600 else "14sp"
                    disabled: root.is_registering
                    text: ""
                    theme_text_color: "Primary"
                    hint_text_color: [0.6, 0.6, 0.6, 1]
                    helper_text_color: [0.5, 0.5, 0.5, 1]
                    text_color: [0, 0, 0, 1]

                # Password with toggle and responsive sizing
                FloatLayout:
                    size_hint_y: None
                    height: dp(56) if Window.width > 600 else dp(48)

                    MDTextField:
                        id: password
                        hint_text: "Create a password"
                        helper_text: "At least 8 characters with letters and numbers"
                        helper_text_mode: "on_focus"
                        password: not root.password_visible
                        mode: "outlined"
                        size_hint: 1, None
                        height: dp(56) if Window.width > 600 else dp(48)
                        font_size: "16sp" if Window.width > 600 else "14sp"
                        pos_hint: {"x": 0, "center_y": 0.5}
                        disabled: root.is_registering
                        text: ""
                        theme_text_color: "Primary"
                        hint_text_color: [0.6, 0.6, 0.6, 1]
                        helper_text_color: [0.5, 0.5, 0.5, 1]
                        text_color: [0, 0, 0, 1]

                    MDIconButton:
                        icon: "eye-off" if root.password_visible else "eye"
                        on_release: root.toggle_password_visibility()
                        pos_hint: {"right": 0.96, "center_y": 0.5}
                        size_hint: None, None
                        size: (dp(40), dp(40)) if Window.width > 600 else (dp(32), dp(32))
                        md_bg_color: 0, 0, 0, 0
                        theme_icon_color: "Custom"
                        icon_color: 0.5, 0.5, 0.5, 1
                        user_font_size: "24sp" if Window.width > 600 else "20sp"

                # Confirm Password with toggle and responsive sizing
                FloatLayout:
                    size_hint_y: None
                    height: dp(56) if Window.width > 600 else dp(48)

                    MDTextField:
                        id: confirm_password
                        hint_text: "Confirm your password"
                        helper_text: "Re-enter the same password"
                        helper_text_mode: "on_focus"
                        password: not root.confirm_password_visible
                        mode: "outlined"
                        size_hint: 1, None
                        height: dp(56) if Window.width > 600 else dp(48)
                        font_size: "16sp" if Window.width > 600 else "14sp"
                        pos_hint: {"x": 0, "center_y": 0.5}
                        disabled: root.is_registering
                        text: ""
                        theme_text_color: "Primary"
                        hint_text_color: [0.6, 0.6, 0.6, 1]
                        helper_text_color: [0.5, 0.5, 0.5, 1]
                        text_color: [0, 0, 0, 1]

                    MDIconButton:
                        icon: "eye-off" if root.confirm_password_visible else "eye"
                        on_release: root.toggle_confirm_password_visibility()
                        pos_hint: {"right": 0.96, "center_y": 0.5}
                        size_hint: None, None
                        size: (dp(40), dp(40)) if Window.width > 600 else (dp(32), dp(32))
                        md_bg_color: 0, 0, 0, 0
                        theme_icon_color: "Custom"
                        icon_color: 0.5, 0.5, 0.5, 1
                        user_font_size: "24sp" if Window.width > 600 else "20sp"

                # Sign-Up button with responsive sizing
                MDButton:
                    style: "elevated"
                    id: signup_button
                    text: "Sign Up"
                    size_hint: 1, None
                    height: dp(56) if Window.width > 600 else dp(48)
                    font_size: "18sp" if Window.width > 600 else "16sp"
                    disabled: root.is_registering
                    on_release: root.signup()
                    md_bg_color: app.theme_cls.primary_color
                    theme_text_color: "Custom"
                    text_color: [1, 1, 1, 1]

                # Spinner container with responsive sizing
                MDBoxLayout:
                    id: spinner_container
                    orientation: "horizontal"
                    adaptive_height: True
                    size_hint_y: None
                    height: dp(40) if root.is_registering else 0
                    opacity: 1 if root.is_registering else 0
                    spacing: dp(12)

                    MDCircularProgressIndicator:
                        id: signup_spinner
                        size_hint: None, None
                        size: (dp(24), dp(24)) if Window.width > 600 else (dp(20), dp(20))
                        active: root.is_registering

                    MDLabel:
                        text: "Creating account..."
                        size_hint_y: None
                        height: self.texture_size[1]
                        font_size: "16sp" if Window.width > 600 else "14sp"
                        theme_text_color: "Primary"

                # Link back to Login with responsive typography
                MDLabel:
                    markup: True
                    text: "[color=888888]Already have an account? [/color][ref=login][color=377DFF]Login[/color][/ref]"
                    halign: "center"
                    size_hint_y: None
                    height: self.texture_size[1] + dp(4)
                    font_size: "14sp" if Window.width > 600 else "12sp"
                    on_ref_press: root.on_login()