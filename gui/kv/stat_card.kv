<StatCard>:
    ripple_behavior: True
    size_hint_y: None
    height: dp(120)
    size_hint_x: 1  # Make it responsive to fill available width
    radius: [12, 12, 12, 12]
    elevation: 2
    padding: dp(16)
    md_bg_color: (0.98, 0.98, 0.98, 1)

    MDBoxLayout:
        orientation: "horizontal"
        spacing: dp(15)
        size_hint: 1, 1

        # Icon section
        MDIconButton:
            icon: root.icon
            theme_icon_color: "Custom"
            icon_color: app.theme_cls.primary_color
            user_font_size: "32sp"
            size_hint_x: None
            width: dp(48)
            pos_hint: {"center_y": 0.5}

        # Content section
        MDBoxLayout:
            orientation: "vertical"
            spacing: dp(2)
            size_hint_x: 1
            pos_hint: {"center_y": 0.5}
            adaptive_height: True

            # Value label (main number)
            MDLabel:
                id: value_label
                text: root.value
                font_size: "24sp"
                halign: "center"
                size_hint_y: None
                height: dp(32)
                
            # Title label
            MDLabel:
                id: title_label
                text: root.title
                font_size: "16sp"
                halign: "center"
                size_hint_y: None
                height: dp(24)
                
            # Note label (additional info)
            MDLabel:
                id: subtitle_label
                text: root.subtitle
                font_size: "12sp"
                halign: "center"
                size_hint_y: None
                height: dp(16) 